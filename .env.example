# Public API base URL — used to call the backend
NUXT_PUBLIC_API_BASE=http://localhost:8000

# Google Gemini API key — obtain from https://aistudio.google.com
# Server-only: never exposed to the browser. If set, users can pick "Gemini (Default)" without entering their own key.
NUXT_GEMINI_API_KEY=your-gemini-api-key-here
